{#
/**
 * @file
 * Main Page Template.
 *
 * Available variables:
 * - page: The content regions for this page.
 * - attributes: HTML attributes for the region div.
 *
 * @see template_preprocess_page()
 * Adds chatbot
 */
#}

{# Template Paths #}
{%- if template_brand_bar is empty -%}
  {%- set template_brand_bar = "@decanter/components/brand-bar/brand-bar.twig" -%}
{%- endif -%}

{%- if template_global_footer is empty -%}
  {%- set template_global_footer = "@decanter/components/global-footer/global-footer.twig" -%}
{%- endif -%}
{# End Template Paths. #}

{# Masthead Section. #}
{%- block block_header -%}
  {%- if page.header or page.search or page.menu -%}
    <header class="su-masthead su-masthead--right" data-nosnippet>

      {% block block_skiplinks %}
        <a href="#main-content" class="visually-hidden focusable su-skipnav su-skipnav--content">
          {{ 'Skip to main content'|t }}
        </a>
        <a href="#secondary-navigation" class="visually-hidden focusable su-skipnav su-skipnav--secondary">
          {{ 'Skip to secondary navigation'|t }}
        </a>
      {% endblock %}

      {# Brand Bar #}
      {%- block block_brandbar -%}
        {%- include template_brand_bar with { modifier_class : brand_bar_variant } -%}
      {%- endblock -%}

      {# Help Section #}
      {%- block block_help -%}
        {{ page.help }}
      {%- endblock -%}

      <section class="su-masthead--inner" aria-label="Page logo, menu and search">
        {% if page.header %}
          <div class="region region-header">
            {{ page.header }}
          </div>
        {% endif %}
        {% if page.search %}
          <div class="region region-search">
            {{ page.search }}
          </div>
        {% endif %}
        {% if page.menu %}
          <div class="region region-menu">
            {{ page.menu }}
          </div>
        {% endif %}
      </section>
    </header>
  {%- endif -%}
{%- endblock -%}

{# Main Page Content Section #}
<main class="page-content" id="page-content">
  {%- block block_main -%}
    {{ page.content }}
  {%- endblock -%}

  <button id="back-to-top">
    <span class="fas fa-chevron-up"></span>
    Back to Top
  </button>
</main>

{# Footer Section #}
{%- block block_footer -%}
  <footer id="footer" data-nosnippet>
    {{ page.footer }}
    {%- include template_global_footer with { modifier_class : global_footer_variant }  -%}
  </footer>
{%- endblock -%}

{# Dialogflow Messenger Integration #}
<div>
    <link rel="stylesheet" href="https://www.gstatic.com/dialogflow-console/fast/df-messenger/prod/v1/themes/df-messenger-default.css">
    <script src="https://www.gstatic.com/dialogflow-console/fast/df-messenger/prod/v1/df-messenger.js"></script>
<body>
    <df-messenger
      location="us-central1"
      project-id="uit-uit-et-servicenow-ai-dev"
      agent-id="b94f606a-5218-479d-8cc9-59f3ec926ae2"
      language-code="en"
      max-query-length="-1"
      allow-feedback="-1">
      <df-messenger-chat-bubble
       chat-title="Admin Guide Assistant"
       bot-writing-text="Generating answer..."
       chat-subtitle="Your AI-Powered guide to Stanford Policies"
       chat-width="360"
    	 chat-height="550"
       placeholder-text="Type a question...">
      </df-messenger-chat-bubble>      
    </df-messenger>

    <style>
      df-messenger {
        z-index: 999;
        position: fixed;
        bottom: 16px;
        right: 16px;
        
  /* correct icon variables */
  --df-messenger-titlebar-icon-font-color: #ffffff;      /* explicit for titlebar icons */
        
        /* Stanford Cardinal Brand Colors */
        --df-messenger-primary-color: #8C1515; /* Stanford Cardinal Red */
        --df-messenger-font-color: #2e2d29; /* Stanford Dark Gray */
        --df-messenger-font-family: 'Source Sans Pro', 'Helvetica Neue', Arial, sans-serif;
        
        /* Chat Interface */
        --df-messenger-chat-background: #ffffff;
        
        /* Message Styling */
        --df-messenger-message-user-background: #8C1515; /* Cardinal Red for user messages */
        --df-messenger-message-user-font-color: #ffffff;
        --df-messenger-message-bot-background: #f4f4f1; /* Stanford Light Gray */
        --df-messenger-message-bot-font-color: #2e2d29;
        --df-messenger-message-border-radius: 18px;
        --df-messenger-message-padding: 12px 16px;
        
        /* Input Field */
        --df-messenger-input-background: #ffffff;
        --df-messenger-input-font-color: #2e2d29;
        --df-messenger-input-border-color: #d4d1c9;
        --df-messenger-input-placeholder-font-color: #767674;
        
        /* Send Button */
        --df-messenger-send-icon-color: #8C1515;
        --df-messenger-send-icon-color-hover: #b91515;
        
        /* Chat Bubble - white with cardinal border for visibility */
        --df-messenger-chat-bubble-background: #ffffff;
        --df-messenger-chat-bubble-icon-color: #8C1515;
        --df-messenger-chat-bubble-border-radius: 50%;
        --df-messenger-chat-bubble-size: 60px;
        
        /* Ensure all icons are white on cardinal background */
        --df-messenger-icon-color: #ffffff;
        --df-messenger-minimize-icon-color: #ffffff;
        --df-messenger-titlebar-subtitle-font-color: #ffffff;
        --df-messenger-close-icon-color: #ffffff;
        
        /* Header */
        --df-messenger-titlebar-background: #8C1515;
        --df-messenger-titlebar-font-color: #ffffff;
        --df-messenger-titlebar-icon-color: #ffffff;
        
        /* Scrollbar */
        --df-messenger-chat-scroll-button-background: #8C1515;
        --df-messenger-chat-scroll-button-background-hover: #b91515;
        --df-messenger-chat-scroll-button-font-color: #ffffff;
        
        /* Feedback buttons */
        --df-messenger-feedback-thumbs-up-color: #8C1515;
        --df-messenger-feedback-thumbs-down-color: #8C1515;
        
        /* Loading animation */
        --df-messenger-loading-circle-color: #8C1515;
        
        /* Additional Stanford styling */
        --df-messenger-bot-writing-background: #f4f4f1;
        --df-messenger-bot-writing-font-color: #767674;
      }
      

    </style>

</div>
